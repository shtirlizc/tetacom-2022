---
const { as = "div", class: className, bodyClass, ...attrs } = Astro.props;

const Tag = as;
const classes = ["_dropdown", className].filter(Boolean).join(" ");
const bodyClasses = ["_dropdown__body", bodyClass].filter(Boolean).join(" ");
---

<Tag class={classes} {...attrs}>
  <slot name="trigger" />
  <div class={bodyClasses}>
    <slot />
  </div>
</Tag>

<style>
  ._dropdown {
    position: relative;
  }

  /*TODO*/
  :global(._dropdown__open-btn) {
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    font: inherit;
    cursor: pointer;
  }

  /* desktop */
  @media (width >= 1081px) {
    ._dropdown__body {
      position: absolute;
      top: calc(100% + 4px);
      left: -4px;
      z-index: 21;
      display: none;
      width: max-content;
      overflow: hidden;
      border-radius: 4px;
      background-color: var(--white-color);
      box-shadow: var(--shadow);
      opacity: 0;
      transform: translateY(-10px);
      transition:
        opacity var(--delay) var(--timing-func),
        transform var(--delay) var(--timing-func);
    }

    ._dropdown__body--right {
      right: -4px;
      left: auto;
    }

    ._dropdown:hover ._dropdown__body,
    ._dropdown:focus-within ._dropdown__body {
      display: block;
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
