---
interface Props {
  rootClass?: string;
  html?: string;
}

const { rootClass, html } = Astro.props as Props;
const classes = ["_text-content", rootClass].filter(Boolean).join(" ");
---

{
  html ? (
    <div class={classes} set:html={html} />
  ) : (
    <div class={classes}>
      <slot />
    </div>
  )
}

<style is:global>
  ._text-content h1,
  ._text-content h2,
  ._text-content h3,
  ._text-content h4,
  ._text-content h5,
  ._text-content h6 {
    margin: 1.45em 0 1.15em;
  }

  ._text-content h1:first-child,
  ._text-content h2:first-child,
  ._text-content h3:first-child,
  ._text-content h4:first-child,
  ._text-content h5:first-child,
  ._text-content h6:first-child,
  ._text-content ol:first-child,
  ._text-content ul:first-child,
  ._text-content figure:first-child,
  ._text-content p:first-child {
    margin-top: 0;
  }

  ._text-content h1:last-child,
  ._text-content h2:last-child,
  ._text-content h3:last-child,
  ._text-content h4:last-child,
  ._text-content h5:last-child,
  ._text-content h6:last-child,
  ._text-content ol:last-child,
  ._text-content ul:last-child,
  ._text-content figure:last-child,
  ._text-content p:last-child {
    margin-bottom: 0;
  }

  ._text-content h1 {
    font-size: 42px;
    line-height: 52px;
  }

  ._text-content h2 {
    font-size: 32px;
    line-height: 38px;
  }

  ._text-content h3 {
    font-size: 24px;
    line-height: 32px;
  }

  ._text-content h4 {
    font-size: 20px;
    line-height: 30px;
  }

  ._text-content h5 {
    font-size: 16px;
    line-height: 24px;
  }

  ._text-content h6 {
    font-size: 12px;
    line-height: 18px;
  }

  ._text-content p {
    margin: 1em 0;
    font-size: 20px;
    line-height: 28px;
  }

  ._text-content ul {
    list-style: none;
  }

  ._text-content ul,
  ._text-content ol {
    margin: 1em 0;
    padding-left: 16px;
  }

  ._text-content ul li,
  ._text-content ol li {
    padding-left: 16px;
    font-size: 18px;
    line-height: 28px;
  }

  ._text-content ul li:not(:last-child),
  ._text-content ol li:not(:last-child) {
    margin-bottom: 0.7em;
  }

  ._text-content ul li {
    position: relative;
  }

  ._text-content ul li::before {
    position: absolute;
    top: 14px;
    left: 0;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background-color: var(--text-color);
    content: "";
  }

  ._text-content img {
    max-width: 100%;
    height: auto;
    cursor: pointer;
    border-radius: 8px;
  }

  ._text-content figure {
    margin: 1.5em 0;
  }

  ._text-content figure > a,
  ._text-content figure img {
    display: block;
  }

  ._text-content figcaption {
    margin-top: 12px;
    color: rgb(0 0 0 / 70%);
    font-size: 16px;
    line-height: 24px;
  }

  ._text-content a {
    color: var(--primary-color);
  }

  ._text-content iframe {
    width: 100%;
    height: auto;
    margin: auto;
    border: none;
    aspect-ratio: 16 / 9;
  }

  ._text-content video {
    display: block;
    width: 100%;
    height: auto;
    margin: 1.5em auto;
    border-radius: 8px;
  }
</style>
