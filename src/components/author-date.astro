---
import { Image } from "astro:assets";

interface Props {
  authorName: string;
  authorAvatar: ImageMetadata;
  dateText: string;
  dateTime: string;
}

const { authorName, authorAvatar, dateText, dateTime } = Astro.props as Props;
---

<div class="_author-date">
  <div class="_author-date__author">
    <div class="_author-date__author-picture">
      <Image src={authorAvatar} alt={authorName} width={28} height={28} />
    </div>
    <p class="_author-date__author-name">{authorName}</p>
  </div>
  <time datetime={dateTime} class="_author-date__date">{dateText}</time>
</div>

<style>
  ._author-date {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  ._author-date__author {
    display: flex;
    align-items: center;
  }

  ._author-date__author-picture {
    width: 28px;
    height: 28px;
    overflow: hidden;
  }

  ._author-date__author-picture :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  ._author-date__author-name {
    margin: 0 0 0 8px;
    color: var(--black-color);
    font-size: 16px;
    line-height: 16px;
  }

  ._author-date__date {
    color: rgb(0 0 0 / 60%);
    font-size: 14px;
    font-weight: 400;
    line-height: 16px;
  }

  /* mobile */
  @media (width < 769px) {
    ._author-date {
      flex-wrap: wrap;
    }
  }
</style>
