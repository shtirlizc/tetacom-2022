---
import Container from "./container.astro";
import Dropdown from "./dropdown.astro";
import Hamburger from "./hamburger.astro";
import { menuItems } from "../data/navigation";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const homeMenuItem = menuItems.find(({ id }) => id === "home");
const productsMenuItem = menuItems.find(({ id }) => id === "products");
const headerLinkItems = menuItems.filter(
  ({ id }) => id !== "home" && id !== "products",
);

const isActivePath = (href: string, exact = false) => {
  if (exact || href === "/") {
    return currentPath === href;
  }

  return currentPath === href || currentPath.startsWith(`${href}/`);
};

const isProductsActive = productsMenuItem
  ? isActivePath(productsMenuItem.href, productsMenuItem.exact)
  : false;
const isHomeActive = homeMenuItem
  ? isActivePath(homeMenuItem.href, homeMenuItem.exact)
  : false;
---

<header class="_header">
  <Container>
    <div class="_header__content">
      <a href="/" class="_header__logo">
