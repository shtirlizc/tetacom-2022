            fill="black"></path>
        </svg>

        <svg
          class="_header__logo-mobile"
          width="28"
          height="28"
          viewBox="0 0 28 28"
          fill="none"
        >
          <path
            d="M5 14C5 16.7734 5.85972 19.0077 7.37651 20.549L8.80199 19.1461C7.88199 18.211 7.22112 16.8424 7.04606 15H20.9539C20.7787 16.842 20.1173 18.2102 19.196 19.1455L20.6209 20.549C22.139 19.0077 23 16.7734 23 14C23 11.2265 22.1403 8.99227 20.6235 7.45102L19.1986 8.85448C20.1186 9.78962 20.779 11.1578 20.954 13H7.04611C7.22128 11.1584 7.88241 9.79041 8.80339 8.85507L7.37909 7.45102C5.86102 8.99227 5 11.2265 5 14Z"
            fill="black"></path>
          <path
            fill-rule="evenodd"
