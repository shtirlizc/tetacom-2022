            d="M24.2992 24.1873C26.6606 21.7898 28 18.3143 28 14C28 9.68574 26.6626 6.2102 24.3032 3.81269C21.9418 1.41519 18.4659 0 14.0181 0C9.5502 0 6.06627 1.41311 3.7008 3.81269C1.33936 6.2102 0 9.68574 0 14C0 18.3143 1.33735 21.7898 3.69679 24.1873C6.05823 26.5848 9.53414 28 13.9819 28C18.4498 28 21.9357 26.5848 24.2992 24.1873ZM13.9819 26C9.96978 26 7.04274 24.7339 5.12227 22.7845C3.20031 20.8311 2 17.8962 2 14C2 10.1046 3.20121 7.17036 5.12511 5.21674C7.04795 3.26651 9.98277 2 14.0181 2C18.0302 2 20.9579 3.26672 22.8783 5.21615C24.8003 7.16947 26 10.1038 26 14C26 17.8958 24.7985 20.8302 22.8743 22.7838C20.9533 24.7322 18.017 26 13.9819 26Z"
            fill="black"></path>
        </svg>
      </a>

      <div class="_header__bg"></div>

      <nav class="_header__navigation">
        <ul class="_header__menu _header__menu--mobile">
          <li class:list={["_header__menu-item", { active: isHomeActive }]}>
            <a
              class="_header__menu-link"
              href={homeMenuItem?.href ?? "/"}
              aria-current={isHomeActive ? "page" : undefined}
            >
              {homeMenuItem?.label ?? "Главная"}
            </a>
          </li>
          <Dropdown
            id="product-list"
            as="li"
            class:list={["_header__menu-item", { active: isProductsActive }]}
          >
            <button
              slot="trigger"
              type="button"
              class="_dropdown__open-btn"
              popovertarget="product-list"
              aria-current={isProductsActive ? "page" : undefined}
            >
              <span class="_header__menu-link">
                {productsMenuItem?.label ?? "Продукты"}
              </span>
            </button>

            <ul class="_header__submenu">
              <li class="_header__submenu-item first">
                <a href="#" class="_header__submenu-link">ГРП</a>
              </li>
              <li class="_header__submenu-item">
                <a href="#" class="_header__submenu-link">Буроптима</a>
              </li>
              <li class="_header__submenu-item">
                <a href="#" class="_header__submenu-link">Эксперия</a>
              </li>
              <li class="_header__submenu-item">
                <a href="#" class="_header__submenu-link">РИР</a>
              </li>
              <li class="_header__submenu-item">
                <a href="#" class="_header__submenu-link">Симулятор ОПЗ</a>
              </li>
              <li class="_header__submenu-item">
                <a href="#" class="_header__submenu-link">ЛИС</a>
              </li>
              <li class="_header__submenu-item last">
                <a href="#" class="_header__submenu-link">НИОКР</a>
              </li>
            </ul>
          </Dropdown>
          {
            headerLinkItems.map(({ label, href, exact }) => (
              <li
                class:list={[
                  "_header__menu-item",
                  { active: isActivePath(href, exact) },
                ]}
              >
                <a
                  class="_header__menu-link"
                  href={href}
                  aria-current={isActivePath(href, exact) ? "page" : undefined}
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>

        <!--<ul class="_header__menu">-->
        <!--  <li class="_header__menu-item">-->
        <!--    <a class="_header__menu-link" href="#">Регистрация</a>-->
        <!--  </li>-->
        <!--  <li class="_header__menu-item">-->
        <!--    <Btn href="#" size="nav-menu">Вход</Btn>-->
        <!--  </li>-->
        <!--</ul>-->
      </nav>

      <div class="_header__hamburger">
        <Hamburger />
      </div>
    </div>
  </Container>
</header>

<script>
  (() => {
    let isClosed = false;
    const toggleBtn = document.getElementById("hamburger");
    const bg = document.querySelector("._header__bg");
    const nav = document.querySelector("._header__navigation");
    const body = document.documentElement;

    if (!toggleBtn || !bg || !nav || !body) {
      return;
    }

    const openMenu = () => {
      bg.classList.add("active");

      window.setTimeout(() => {
        bg.classList.add("visible");
        nav.classList.add("active");
        body.classList.add("mobile-menu");
      }, 50);
    };

    const closeMenu = () => {
      bg.classList.remove("visible");
      nav.classList.remove("active");
      body.classList.remove("mobile-menu");

      window.setTimeout(() => {
        bg.classList.remove("active");
      }, 500);
    };

    toggleBtn.addEventListener("click", () => {
      if (isClosed) {
        toggleBtn.classList.remove("is-open");
        toggleBtn.classList.add("is-closed");
        isClosed = false;
        closeMenu();
        return;
      }

      toggleBtn.classList.remove("is-closed");
      toggleBtn.classList.add("is-open");
      isClosed = true;
      openMenu();
    });

    bg.addEventListener("click", () => {
      toggleBtn.classList.remove("is-open");
      toggleBtn.classList.add("is-closed");
      isClosed = false;
      closeMenu();
    });
  })();
</script>

<style>
  ._header {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    width: 100%;
    background-color: var(--bg-color);

    @supports ((animation-timeline: scroll()) and (animation-range: 0 100px)) {
      background-color: transparent;
      animation: header-bg 1s linear;
      animation-timeline: scroll(root block);
      animation-range: 0 100px;
      animation-fill-mode: both;
    }
  }

  @keyframes header-bg {
    from {
      background-color: transparent;
      box-shadow: 0 0 40px rgba(0, 0, 0, 0);
    }

    to {
      background-color: var(--bg-color);
      box-shadow: 0 0 40px rgba(0, 0, 0, 0.4);
    }
  }

  ._header__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
  }

  ._header__logo {
    z-index: 1;
    height: 26px;
  }

  ._header__logo svg path {
    transition: fill var(--delay) var(--timing-func);
  }

  ._header__logo:hover svg path {
    fill: var(--primary-color);
  }

  ._header__bg {
    position: fixed;
    inset: 0;
    display: none;
    background-color: var(--black-color);
    opacity: 0;
    transition: opacity calc(1.5 * var(--delay)) var(--timing-func);
  }

  ._header__bg.active {
    display: block;
  }

  ._header__bg.visible {
    opacity: 0.5;
  }

  ._header__navigation {
    --padd: 48px;

    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: calc(2 * var(--padd) + 1px);
  }

  ._header__navigation > *:not(:last-child) {
    position: relative;
  }

  ._header__navigation > *:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 50%;
    right: calc(-1 * var(--padd) - 1px);
    width: 1px;
    height: 16px;
    transform: translateY(-50%);
    background-color: rgb(0 0 0 / 10%);
  }

  ._header__menu,
  ._header__submenu {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  ._header__menu {
    display: flex;
    align-items: center;
    gap: 48px;
  }

  ._header__menu-link,
  ._header__submenu-link {
    display: block;
    padding: var(--space2x) 0;
    color: var(--black-color);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    transition: color var(--delay) var(--timing-func);
  }

  ._header__menu-link:hover,
  ._header__submenu-link:hover {
    color: var(--primary-color);
  }

  ._header__menu-item.active > ._header__menu-link,
  ._header__menu-item.active > ._dropdown__open-btn ._header__menu-link {
    color: var(--primary-color);
  }

  ._header__submenu {
    padding: var(--space) var(--space2x);
  }

  ._header__submenu-link {
    padding: var(--space) 0;
  }

  ._header__hamburger {
    cursor: pointer;
  }

  /* mobile */
  @media (width < 769px) {
    ._header__logo-desktop {
      display: none;
    }
  }

  /* tablet */
  @media (width >= 769px) {
    ._header__logo-mobile {
      display: none;
    }
  }

  /* touch */
  @media (width < 1081px) {
    ._header__navigation {
      position: fixed;
      right: -241px;
      bottom: 0;
      width: 240px;
      height: 100%;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 20px;
      padding: calc(2 * var(--space3x)) var(--space3x);
      overflow-x: hidden;
      overflow-y: scroll;
      background-color: var(--bg-color);
      transition: right calc(1.5 * var(--delay)) var(--timing-func);
    }

    ._header__navigation.active {
      right: 0;
    }

    ._header__navigation > *:not(:last-child)::after {
      display: none;
    }

    ._header__menu {
      gap: 20px;
    }

    ._header__menu-link {
      padding: calc(1.5 * var(--space)) 0;
    }

    ._header__menu--mobile {
      display: block;
      width: 100%;
    }

    ._header__bg.active {
      display: block;
    }
  }

  /* desktop */
  @media (width >= 1081px) {
    ._header__content {
      padding: 20px 0;
    }

    ._header__logo {
      transform: translateY(-3px);
    }

    ._header__hamburger {
      display: none;
    }
  }
</style>
