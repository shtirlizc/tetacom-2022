---
import type { HTMLTag } from "astro/types";

interface Props {
  as?: HTMLTag;
  rootClass?: string;
  mobileAlign?: "left" | "center";
}

const { as = "h1", rootClass, mobileAlign = "left" } = Astro.props as Props;

const Tag = as;
const classes = ["_page-title", rootClass].filter(Boolean).join(" ");
---

<Tag class={classes} data-mobile-align={mobileAlign}>
  <slot />
</Tag>

<style>
  ._page-title {
    margin: 0;
    font-size: 60px;
    line-height: 71px;
    letter-spacing: -2px;
  }

  /* touch */
  @media (width < 1081px) {
    ._page-title {
      font-size: 42px;
      line-height: 1.1em;
    }
  }

  /* mobile */
  @media (width < 769px) {
    ._page-title[data-mobile-align="center"] {
      text-align: center;
    }
  }
</style>
