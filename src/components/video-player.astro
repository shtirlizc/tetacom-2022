---
interface Props {
  src: string;
  poster?: string;
  label?: string;
}

const { src, poster, label = "Видео" } = Astro.props as Props;
---

<div class="_video-player" data-video-player>
  <video
    class="_video-player__media"
    src={src}
    poster={poster}
    controls
    playsinline
    preload="metadata"
    aria-label={label}></video>
</div>

<script>
  import { initVideoPlayers } from "../scripts/video-player";

  initVideoPlayers();
</script>
