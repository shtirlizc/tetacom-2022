---
import Cookie from "../components/cookie.astro";
import Head from "../components/head.astro";
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import Popovers from "../components/popovers.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
}

const { title, description, canonical, image, type } = Astro.props as Props;
---

<!doctype html>
<html lang="ru">
  <Head
    title={title}
    description={description}
    canonical={canonical}
    image={image}
    type={type}
  />

  <body class="full-height">
    <Header />

    <slot />

    <Footer />
    <Popovers />
    <Cookie />
  </body>
</html>

<style>
  .full-height {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
