---
import TextContent from "../../components/text-content.astro";

interface FaqItem {
  title: string;
  contentHtml?: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props as Props;
---

<section class="_faq">
  <h2 class="_faq__title">FAQ</h2>
  <div class="_faq__body _accordion js-accordion">
    {
      items.map(({ title, contentHtml }) => (
        <div class="ac _accordion__item">
          <h3 class="ac-header _accordion__header">
            <button type="button" class="_accordion__button ac-trigger">
              {title}
              <span class="_accordion__button-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path
                    d="M10 1V19M1 10H19"
                    stroke="black"
                    stroke-opacity="0.87"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                </svg>
              </span>
            </button>
          </h3>
          <div class="ac-panel _accordion__panel">
            <TextContent
              rootClass="_accordion__panel-content"
              html={contentHtml}
            />
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  ._faq__title {
    font-size: 40px;
    text-align: center;
  }

  ._faq__body {
    margin-top: 45px;
  }

  ._accordion {
    --padding: 30px 24px;
  }

  ._accordion__item:not(:last-child) {
    border-bottom: 1px solid rgb(0 0 0 / 10%);
  }

  ._accordion__header {
    margin: 0;
  }

  ._accordion__button {
    position: relative;
    display: block;
    width: 100%;
    padding: var(--padding);
    padding-right: 92px;
    border: none;
    background: none;
    color: var(--black-color);
    font-size: 32px;
    font-family: inherit;
    text-align: left;
    cursor: pointer;
    transition: color var(--delay) var(--timing-func);
  }

  ._accordion__button-icon {
    position: absolute;
    top: 50%;
    right: 22px;
    display: flex;
    align-items: center;
    padding: 9px 17px;
    border: 2px solid var(--black-color);
    border-radius: 28px;
    font-size: 0;
    transform: translateY(-50%);
    transition:
      height var(--delay) var(--timing-func),
      border var(--delay) var(--timing-func);
  }

  ._accordion__button-icon svg {
    transition: transform var(--delay) var(--timing-func);
  }

  ._accordion__button-icon svg path {
    transition: stroke var(--delay) var(--timing-func);
  }

  ._accordion__button:hover {
    color: var(--primary-color);
  }

  ._accordion__button:hover ._accordion__button-icon {
    border-color: var(--primary-color);
  }

  ._accordion__button:hover svg path {
    stroke: var(--primary-color);
  }

  ._accordion__button[aria-expanded="true"] ._accordion__button-icon svg {
    transform: rotate(45deg);
  }

  ._accordion__panel {
    overflow: hidden;
    transition: height 250ms var(--timing-func);
  }

  :global(._accordion__panel-content) {
    padding: var(--padding);
    padding-top: 0;
  }

  :global(._accordion__panel-content:empty) {
    display: none;
  }

  /* mobile */
  @media (width < 769px) {
    ._accordion {
      --padding: 16px;
    }

    ._accordion__button {
      padding-right: 72px;
      font-size: 20px;
    }

    ._accordion__button-icon {
      padding: 8px;
    }
  }
</style>

<script>
  import Accordion from "accordion-js";

  new Accordion(
    Array.from(document.querySelectorAll<HTMLElement>("._faq .js-accordion")),
    {
      duration: 250,
      showMultiple: true,
    },
  );
</script>
