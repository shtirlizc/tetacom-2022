---
import ink from "../../assets/partners/ink.svg";
import kzu from "../../assets/partners/kzu.svg";
import lukoil from "../../assets/partners/lukoil.svg";
import tatneft from "../../assets/partners/tatneft.svg";
import ugntu from "../../assets/partners/ugntu.svg";

const partners = [
  { logo: lukoil, name: "Lukoil" },
  { logo: tatneft, name: "Tatneft" },
  { logo: kzu, name: "KZU" },
  { logo: ink, name: "INK" },
  { logo: ugntu, name: "UGNTU" },
];
---

<section class="_partners">
  <h2 class="_partners__title">С нами работают</h2>

  <ul class="_partners__body">
    {
      partners.map((partner) => {
        const Logo = partner.logo;

        return (
          <li class="_partners__item">
            <Logo role="img" aria-label={partner.name} />
          </li>
        );
      })
    }
  </ul>
</section>

<style>
  ._partners {
    padding: 60px 0 120px;
  }

  ._partners__title {
    font-size: 40px;
    font-weight: 600;
    line-height: 47px;
    text-align: center;
  }

  ._partners__body {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space5x);
    margin: 40px 0 0;
    padding: 0;
    list-style: none;
  }

  ._partners__item {
    display: flex;
    align-items: center;
    height: 100%;
    font-size: 0;
    text-align: center;
  }

  ._partners__item :global(svg) {
    max-width: 100%;
    max-height: 100%;
  }

  /* tablet */
  @media (width >= 769px) {
    ._partners {
      padding: 60px 0 180px;
    }

    ._partners__body {
      flex-direction: row;
      justify-content: space-between;
      gap: 40px 20px;
    }
  }

  /* desktop */
  @media (width >= 1081px) {
    ._partners__body {
      gap: 40px 80px;
      margin-top: 80px;
      justify-content: space-between;
    }
  }

  /* fullhd */
  @media (width >= 1440px) {
    ._partners__body {
      gap: 40px 160px;
    }
  }
</style>
