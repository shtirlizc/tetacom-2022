---
import { Image } from "astro:assets";
import product1 from "../../assets/products/product-1.png";
import product2 from "../../assets/products/product-2.png";
import product3 from "../../assets/products/product-3.svg";
import product4 from "../../assets/products/product-4.png";

const Product3 = product3;
---

<div class="_capabilities">
  <div class="_capabilities__items js-sticky-track">
    <article class="_capabilities__item">
      <div
        class="_capabilities__item-content"
        style="background-color: #3c5df2"
      >
        <div class="_capabilities__item-info">
          <h3 class="_capabilities__item-title">
            Симулятор гидроразрыва<br />пласта
          </h3>
          <a href="#" class="_capabilities__item-link">
            Обзор продукта
            <span style="background-color: #353749">
              <svg width="23" height="18" viewBox="0 0 23 18" fill="none">
                <path
                  d="M1.5 9L21.5 9M21.5 9L13.1 1M21.5 9L13.1 17"
                  stroke="#ffffff"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </a>
        </div>
        <div class="_capabilities__item-picture">
          <Image src={product1} alt="" width={628} height={420} />
        </div>
      </div>
    </article>

    <article class="_capabilities__item">
      <div
        class="_capabilities__item-content"
        style="background-color: #353749"
      >
        <div class="_capabilities__item-info">
          <h3 class="_capabilities__item-title">
            Симулятор обработки призабойных зон
          </h3>
          <a href="#" class="_capabilities__item-link">
            Написать нам
            <span style="background-color: #3c5df2">
              <svg width="23" height="18" viewBox="0 0 23 18" fill="none">
                <path
                  d="M1.5 9L21.5 9M21.5 9L13.1 1M21.5 9L13.1 17"
                  stroke="#ffffff"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </a>
        </div>
        <div class="_capabilities__item-picture">
          <Image src={product2} alt="" width={628} height={420} />
        </div>
      </div>
    </article>

    <article class="_capabilities__item">
      <div
        class="_capabilities__item-content"
        style="background-color: #8792a9"
      >
        <div class="_capabilities__item-info">
          <h3 class="_capabilities__item-title">
            Удаленный мониторинг и аналитика бурения
          </h3>
          <a href="#" class="_capabilities__item-link">
            Обзор продукта
            <span style="background-color: #ffffff">
              <svg width="23" height="18" viewBox="0 0 23 18" fill="none">
                <path
                  d="M1.5 9L21.5 9M21.5 9L13.1 1M21.5 9L13.1 17"
                  stroke="#8792a9"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </a>
        </div>
        <div class="_capabilities__item-picture">
          <Product3 aria-hidden="true" focusable="false" />
        </div>
      </div>
    </article>

    <article class="_capabilities__item">
      <div
        class="_capabilities__item-content"
        style="background-color: #8a6eba"
      >
        <div class="_capabilities__item-info">
          <h3 class="_capabilities__item-title">
            Построение графика исследований
          </h3>
          <a href="#" class="_capabilities__item-link">
            Обзор продукта
            <span style="background-color: #353749">
              <svg width="23" height="18" viewBox="0 0 23 18" fill="none">
                <path
                  d="M1.5 9L21.5 9M21.5 9L13.1 1M21.5 9L13.1 17"
                  stroke="#ffffff"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </a>
        </div>
        <div class="_capabilities__item-picture">
          <Image src={product4} alt="" width={628} height={420} />
        </div>
      </div>
    </article>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const leftPoints = [13, 103, 33, 83, 128];
  const offsetTop = 120;
  const difference = 140;
  const track = document.querySelector(".js-sticky-track");

  if (track instanceof HTMLElement && !track.classList.contains("is-ready")) {
    type CardHeight = {
      index: number;
      height: number;
    };

    let cards: HTMLElement[] = [];
    let cardsHeightMap: CardHeight[] = [];
    let currentCardNumber: number | null = null;

    const calcCardsHeight = () => {
      cardsHeightMap = [];

      cards.forEach((card, index) => {
        const lastItem = cardsHeightMap[cardsHeightMap.length - 1];
        cardsHeightMap.push({
          index,
          height: lastItem
            ? card.offsetHeight + lastItem.height
            : card.offsetHeight,
        });
      });
    };

    const toFixedCards = () => {
      cards.forEach((card, index) => {
        const top = index * difference + offsetTop;
        const clientRect = card.getBoundingClientRect();

        card.style.position = "fixed";
        card.style.left = `${clientRect.x}px`;
        card.style.top = `${top}px`;
      });
    };

    const toUnFixedCards = () => {
      cards.forEach((card, index) => {
        const top = index * difference;
        const left = leftPoints[index % leftPoints.length];

        card.style.position = "absolute";
        card.style.top = `${top}px`;
        card.style.left = `${left}px`;
        card.style.zIndex = `${cards.length - index}`;
      });
    };

    const shiftCards = (shiftBase: number) => {
      if (currentCardNumber === null) {
        return;
      }

      const activeCardNumber = currentCardNumber;
      const shiftValue = shiftBase + activeCardNumber * difference;

      cards.forEach((card, index) => {
        let transformValue;

        if (index - activeCardNumber < 0) {
          transformValue = -1000 * cards.length;
        } else if (index - activeCardNumber === 0) {
          transformValue = -5 * shiftBase - shiftValue;
        } else {
          transformValue = -1 * shiftValue;
        }

        gsap.to(card, {
          transform: `translateY(${transformValue}px)`,
        });
      });
    };

    const clearShifts = () => {
      if (currentCardNumber === null) {
        return;
      }

      const activeCardNumber = currentCardNumber;
      const shiftValue = activeCardNumber * difference;

      cards.forEach((card, index) => {
        if (index >= activeCardNumber) {
          gsap.to(card, {
            transform: `translateY(${-1 * shiftValue}px)`,
          });
        }
      });
    };

    const scrollTracking = () => {
      if (currentCardNumber === null) {
        return;
      }

      const trackY = track.getBoundingClientRect().y;
      const currentCard = cardsHeightMap[currentCardNumber];

      if (!currentCard) {
        return;
      }

      const divider = currentCard.height + trackY - offsetTop;

      if (divider <= difference) {
        shiftCards(Math.abs(divider - difference));
        return;
      }

      clearShifts();
    };

    const listenTrackScrolling = () => {
      const trackY = track.getBoundingClientRect().y;
      const trackHeight = Number.parseInt(track.style.height || "0", 10);

      if (trackY <= offsetTop && trackY + trackHeight > offsetTop) {
        if (currentCardNumber === null) {
          toFixedCards();
        }

        const currentCard = cardsHeightMap.find(
          (card) => card.height > Math.abs(trackY - offsetTop),
        );

        if (currentCard) {
          currentCardNumber = currentCard.index;
        }
      } else if (trackY > 0) {
        if (currentCardNumber !== null) {
          toUnFixedCards();
        }

        currentCardNumber = null;
      }

      if (currentCardNumber !== null) {
        scrollTracking();
      }
    };

    const destroySticky = () => {
      track.style.marginBottom = "0";
      track.style.height = "auto";
      document.removeEventListener("scroll", listenTrackScrolling);

      cards.forEach((card) => {
        card.removeAttribute("style");
        gsap.to(card, {
          transform: "translate(0)",
        });
      });
    };

    const setup = () => {
      track.style.marginBottom = "50vh";
      cards = Array.from(track.children).filter(
        (card): card is HTMLElement => card instanceof HTMLElement,
      );

      const trackHeight = cards.reduce((sum, element) => {
        return sum + element.offsetHeight;
      }, 0);

      track.style.height = `${trackHeight}px`;

      calcCardsHeight();

      const trackY = track.getBoundingClientRect().y;
      const lastCard = cardsHeightMap[cardsHeightMap.length - 1];

      if (!lastCard) {
        return;
      }

      const divider = lastCard.height + trackY - offsetTop;

      toUnFixedCards();

      if (trackY < 0) {
        currentCardNumber = cards.length - 1;
        toFixedCards();
        shiftCards(Math.abs(divider - difference));
      }

      document.removeEventListener("scroll", listenTrackScrolling);
      document.addEventListener("scroll", listenTrackScrolling, {
        passive: true,
      });
    };

    const setMode = () => {
      cards = Array.from(track.children).filter(
        (card): card is HTMLElement => card instanceof HTMLElement,
      );
      calcCardsHeight();

      if (window.innerWidth > 1080) {
        setup();
        return;
      }

      destroySticky();
    };

    let resizeTimeout = 0;
    const onResize = () => {
      window.clearTimeout(resizeTimeout);
      resizeTimeout = window.setTimeout(() => {
        setMode();
      }, 50);
    };

    setMode();
    window.addEventListener("resize", onResize);
    track.classList.add("is-ready");
  }
</script>

<style>
  ._capabilities__items {
    position: relative;
    margin-top: var(--space5x);
  }

  ._capabilities__item {
    width: calc(100vw - 32px);
    overflow: hidden;
    border-radius: 20px;
    color: var(--white-color);
  }

  ._capabilities__item-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    padding: 92px 60px;
  }

  ._capabilities__item-title {
    font-size: 40px;
    line-height: 47px;
  }

  ._capabilities__item-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 20px;
    color: inherit;
    font-size: 16px;
    text-decoration: none;
  }

  ._capabilities__item-link span {
    display: flex;
    flex: 0 0 52px;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    transition: transform var(--delay) ease-in-out;
  }

  ._capabilities__item-link:hover span {
    transform: translate(10px);
  }

  ._capabilities__item-picture :global(img),
  ._capabilities__item-picture :global(svg) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* mobile */
  @media (width < 769px) {
    ._capabilities__items {
      display: grid;
      justify-content: center;
      gap: var(--space3x);
    }

    ._capabilities__item-info {
      padding: 32px;
    }

    ._capabilities__item-title {
      font-size: 24px;
      line-height: 1.1em;
    }

    ._capabilities__item-picture {
      display: none;
    }
  }

  /* tablet */
  @media (width >= 769px) {
    ._capabilities__items {
      display: grid;
      justify-content: center;
      gap: var(--space3x);
    }

    ._capabilities__item {
      width: 628px;
    }

    ._capabilities__item-content {
      display: grid;
      grid-template-columns: 1fr 430px;
    }
  }

  /* tablet-only */
  @media (width >= 769px) and (width < 1081px) {
    ._capabilities__item-info {
      padding: 44px 32px;
    }

    ._capabilities__item-title {
      font-size: 32px;
      line-height: 1.1em;
    }
  }

  /* desktop */
  @media (width >= 1081px) {
    ._capabilities__item {
      position: absolute;
      left: 0;
      transform-style: preserve-3d;
    }

    ._capabilities__item {
      width: 880px;
    }
  }

  /* widescreen */
  @media (width >= 1200px) {
    ._capabilities__item {
      width: 920px;
    }
  }

  /* fullhd */
  @media (width >= 1440px) {
    ._capabilities__item {
      width: 1190px;
    }
  }
</style>
