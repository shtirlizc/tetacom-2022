---
import Btn from "../components/btn.astro";
import Container from "../components/container.astro";
import Layout from "../layouts/layout.astro";
import PageTitle from "../components/page-title.astro";
import NewsPreview from "../blocks/news/news-preview.astro";
import avatar1Image from "../assets/news/avatars/avatar-1.jpg";
import avatar2Image from "../assets/news/avatars/avatar-2.jpg";

const filters = [
  { label: "Все новости", href: "#", active: true },
  { label: "Образование", href: "#" },
  { label: "Наука и инновации", href: "#" },
  { label: "Достижения", href: "#" },
  { label: "RockStim", href: "#" },
  { label: "RockFrac", href: "#" },
  { label: "RockWow", href: "#", tag: "RockWow" },
];

const newsItems = [
  {
    authorName: "Марат Ситдиков",
    authorAvatar: avatar1Image,
    dateText: "7 Июля, 13:31",
    dateTime: "7 Июля, 13:31",
    title:
      "Ретроспективный анализ двухстадийной солянокислотной обработки с закачкой",
    tags: [{ label: "Образование" }, { label: "Наука и инновации" }],
    intro:
      "Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id es. Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatu",
    href: "#",
  },
  {
    authorName: "Роман Касливцев",
    authorAvatar: avatar2Image,
    dateText: "30 Июня, 13:06",
    dateTime: "30 Июня, 13:06",
    title:
      "Как учесть возникающее явление раскрытия естественных трещин коллектора при моделировании ОПЗ?",
    tags: [{ label: "RockFrac" }, { label: "RockStim" }],
    intro:
      "Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatu",
    href: "#",
  },
  {
    authorName: "Данияр Галимханов",
    authorAvatar: avatar2Image,
    dateText: "23 Июня, 13:06",
    dateTime: "23 Июня, 13:06",
    title: "Ретроспективный анализ обработки горизонтальной нефтедобывающей скважины",
    tags: [{ label: "RockStim" }, { label: "Наука и инновации" }],
    intro:
      "Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatu",
    href: "#",
  },
];
---

<Layout>
  <main class="page-main">
    <Container>
      <div class="_news-page">
        <PageTitle as="h1" rootClass="_news-page__title">Новости</PageTitle>

        <div class="_news-page__filter">
          {
            filters.map(({ label, href, active = false, tag }) => (
              <Btn
                href={href}
                size="small"
                variant="text"
                class={active ? "active" : undefined}
                data-tag={tag}
              >
                {label}
              </Btn>
            ))
          }
        </div>

        <div class="_news-page__feed">
          {
            newsItems.map((item) => (
              <NewsPreview
                authorName={item.authorName}
                authorAvatar={item.authorAvatar}
                dateText={item.dateText}
                dateTime={item.dateTime}
                title={item.title}
                tags={item.tags}
                intro={item.intro}
                href={item.href}
              />
            ))
          }
        </div>
      </div>
    </Container>
  </main>
</Layout>

<style>
  .page-main {
    flex: 1;
  }

  ._news-page {
    padding: 180px 0 164px;
  }

  ._news-page__filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-top: 60px;
  }

  :global(._news-page__filter ._btn.active) {
    border: 2px solid var(--primary-color);
    background-color: var(--primary-color);
    color: var(--white-color);
  }

  :global(._news-page__filter ._btn.active:hover) {
    background-color: transparent;
    color: var(--primary-color);
  }

  ._news-page__feed {
    display: grid;
    gap: 60px;
    margin-top: 60px;
  }

  /* mobile */
  @media (width < 769px) {
    ._news-page {
      padding: 80px 0;
    }
  }

  /* tablet */
  @media (width >= 769px) {
    ._news-page__feed {
      padding-right: 20%;
    }
  }

  /* tablet-only */
  @media (width >= 769px) and (width < 1081px) {
    ._news-page {
      padding: 120px 0;
    }
  }

  /* desktop */
  @media (width >= 1081px) {
    ._news-page__feed {
      padding-right: 35%;
    }
  }
</style>
