---
import { getCollection } from "astro:content";
import Layout from "../../layouts/layout.astro";
import BlogFeed from "../../blocks/news/blog-feed.astro";
import { getBlogTagBySlug } from "../../data/blog-tags";

const formatPostDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);

const blogEntries = (
  await getCollection("blog", ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const usedTagSlugs = Array.from(
  new Set(blogEntries.flatMap(({ data }) => data.tags)),
);
const filters = [
  { label: "Все статьи", href: "/blog/", active: true },
  ...usedTagSlugs.map((slug) => {
    const tag = getBlogTagBySlug(slug);

    return {
      label: tag?.label ?? slug,
      href: `/blog/tag/${slug}/`,
      active: false,
    };
  }),
];
const newsItems = blogEntries.map(({ data }) => ({
  dateText: formatPostDate(data.pubDate),
  dateTime: data.pubDate.toISOString(),
  title: data.title,
  tagSlugs: data.tags,
  tags: data.tags.map((slug) => {
    const tag = getBlogTagBySlug(slug);

    return {
      label: tag?.label ?? slug,
      href: `/blog/tag/${slug}/`,
    };
  }),
  intro: data.description,
  href: `/blog/${data.slug}/`,
}));
---

<Layout title="Блог" canonical={new URL("/blog/", Astro.site).toString()}>
  <BlogFeed title="Блог" filters={filters} items={newsItems} />
</Layout>
