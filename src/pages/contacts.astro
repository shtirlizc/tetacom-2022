---
import Container from "../components/container.astro";
import Layout from "../layouts/layout.astro";
import LinkBlock from "../components/link-block.astro";

const contactLinks = [
  {
    title: "Заказать демонстрацию",
    description: "Покажем продукты и обучим специалистов",
    href: "#",
    linkLabel: "Заказать демонстрацию",
  },
  {
    title: "Телеграм",
    description: "@slava.nikulin",
    href: "tg://resolve?domain=slava.nikulin",
    linkLabel: "@slava.nikulin",
  },
  {
    title: "E-mail",
    description: "info@tetacom.pro",
    href: "mailto:info@tetacom.pro",
    linkLabel: "info@tetacom.pro",
  },
];
---

<Layout>
  <main class="page-main">
    <Container>
      <div class="_contacts-page">
        <div class="_contacts-page__info">
          <h1 class="_contacts-page__title">
            Мы готовы ответить на ваши вопросы
          </h1>
          <p class="_contacts-page__description">
            Если у вас остались какие-то вопросы - просто свяжитесь с нами.
            Расскажем про наши продукты, обучим персонал, рассмотрим ваши идеи
            по разработке продуктов
          </p>
        </div>

        <div class="_contacts-page__links">
          <LinkBlock items={contactLinks} />
        </div>

        <div class="_contacts-page__bottom">
          <div class="_contacts-page__bottom-item">
            <p class="_contacts-page__bottom-name">Адрес</p>
            <address class="_contacts-page__bottom-value">
              Иннополис,<br />
              ул. Университетская, 7<br />
              офис 503
            </address>
          </div>
          <div class="_contacts-page__bottom-item">
            <p class="_contacts-page__bottom-name">Телефон</p>
            <p class="_contacts-page__bottom-value">
              <a href="tel:8 800 250-02-24">8 800 250-02-24</a>
            </p>
          </div>
          <div class="_contacts-page__bottom-item">
            <p class="_contacts-page__bottom-name">E-mail</p>
            <p class="_contacts-page__bottom-value">
              <a href="mailto:info@tetacom.pro">info@tetacom.pro</a>
            </p>
          </div>
        </div>
      </div>
    </Container>
  </main>
</Layout>

<style>
  .page-main {
    flex: 1;
  }

  ._contacts-page {
    display: grid;
    gap: 40px;
    padding: 180px 0 150px;
  }

  ._contacts-page__title {
    margin: 0;
    font-size: 40px;
    line-height: 47px;
  }

  ._contacts-page__description {
    margin: 60px 0 0;
    font-size: 18px;
    line-height: 156%;
  }

  ._contacts-page__bottom {
    display: grid;
    gap: 20px;
  }

  ._contacts-page__bottom-name {
    margin: 0;
    color: rgb(0 0 0 / 60%);
    font-size: 18px;
    line-height: 156%;
  }

  ._contacts-page__bottom-value {
    margin: 16px 0 0;
    font-size: 28px;
    font-style: normal;
    line-height: 33px;
  }

  ._contacts-page__bottom-value a {
    color: inherit;
    transition: color var(--delay) var(--timing-func);
  }

  ._contacts-page__bottom-value a:hover {
    color: var(--primary-color);
  }

  /* mobile */
  @media (width < 769px) {
    ._contacts-page {
      padding: 80px 0;
    }

    ._contacts-page__description {
      margin-top: 30px;
    }
  }

  /* tablet */
  @media (width >= 769px) {
    ._contacts-page {
      grid-template-columns: 1fr 40vw;
      grid-template-rows: min-content auto;
      gap: 80px 20px;
    }

    ._contacts-page__bottom {
      grid-column: 1 / 3;
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* tablet-only */
  @media (width >= 769px) and (width < 1081px) {
    ._contacts-page {
      padding: 120px 0;
    }
  }

  /* touch */
  @media (width < 1081px) {
    ._contacts-page__bottom-value {
      font-size: 22px;
      line-height: 1.2em;
    }
  }

  /* desktop */
  @media (width >= 1081px) {
    ._contacts-page {
      grid-template-columns: 1fr 530px;
      gap: 130px 20px;
    }

    ._contacts-page__info {
      padding-right: 30%;
    }
  }
</style>
