---
import Btn from "../components/btn.astro";
import Container from "../components/container.astro";
import Feedback from "../components/feedback.astro";
import Form from "../components/form.astro";
import HorizontalBanner from "../components/horizontal-banner.astro";
import Input from "../components/input.astro";
import Layout from "../layouts/layout.astro";
import PageTitle from "../components/page-title.astro";
import PromptBlock from "../components/prompt-block.astro";
import TextContent from "../components/text-content.astro";
import CourseProgram from "../blocks/course/course-program.astro";
import Faq from "../blocks/course/faq.astro";
import SliderOneSlide from "../blocks/course/slider-one-slide.astro";
import product2Image from "../assets/products/product-2.png";
import resumeBgImage from "../assets/course/resume-bg.png";
import slide1Image from "../assets/course/slide-1.jpg";
import slide2Image from "../assets/course/slide-2.jpg";
import slide3Image from "../assets/course/slide-3.jpg";

const slides = [
  { image: slide1Image, alt: "Описание" },
  { image: slide2Image, alt: "Описание" },
  { image: slide3Image, alt: "Описание" },
];

const courseProgramItems = [
  {
    day: "1 день",
    title: "Особенности воздействия обработок в карбонатных коллекторах",
    contentHtml: `
      <ul>
        <li>Вводная лекция, как пользоваться симулятором RockStim</li>
        <li>Особенности воздействия обработок в карбонатных коллекторах</li>
        <li>Моделирование собственной скважины с учётом обработок</li>
      </ul>
    `,
  },
  {
    day: "2 день",
    title: "Обработки терригенных коллекторов и осложняющие факторы",
    contentHtml: "",
  },
  {
    day: "3 день",
    title: "Лабораторные исследования, жидкостей и реагентов СКО, ОВП",
    contentHtml: "",
  },
  {
    day: "4 день",
    title:
      "Моделирование и оптимизация эффектов от воздействия в симуляторе RockStim",
    contentHtml: "",
  },
];

const faqItems = [
  {
    title: "Кто будет меня учить?",
    contentHtml:
      "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>",
  },
  {
    title: "Каким требованиям мне нужно соответствовать?",
    contentHtml:
      "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>",
  },
  {
    title: "Чем подтверждено право на проведение образовательной деятельности?",
    contentHtml:
      "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>",
  },
  {
    title: "Какой документ выдается после прохождения курса?",
    contentHtml: "",
  },
  {
    title: "Имеют ли срок действия документы о квалификации?",
    contentHtml: "<p>Срока действия документы о квалификации не имеют.</p>",
  },
];

const courseFeedbackDescriptionItems = [
  {
    key: "Ближайший старт:",
    value: "По мере формирования группы",
  },
  {
    key: "Формат:",
    value: "Очно",
  },
  {
    key: "Сколько учиться:",
    value: "4 дня",
  },
];
---

<Layout>
  <main class="page-main">
    <Container>
      <div class="_course">
        <section class="_course__start">
          <h3 class="_course__point">Программа повышения квалификации</h3>
          <PageTitle as="h1" rootClass="_course__title">
            Продвинутый курс по кислотным обработкам и реагентам
          </PageTitle>
          <p class="_course__description">
            Для специалистов нефтегазодобывающих, нефтесервисных и
            научно-проектных предприятий, имеющие среднее или высшее
            специально-техническое образование, которые получат теоретические
            знания и практические навыки моделирования в симуляторе ОПЗ.
          </p>
          <ul class="_course__props">
            <li class="_course__props-item">
              <span class="_course__props-key">Стоимость:</span>
              <span class="_course__props-value">70 000 ₽</span>
            </li>
            <li class="_course__props-item">
              <span class="_course__props-key">Дата начала:</span>
              <span class="_course__props-value"
                >По мере формирования группы</span
              >
            </li>
            <li class="_course__props-item">
              <span class="_course__props-key">Формат:</span>
              <span class="_course__props-value">Очно</span>
            </li>
            <li class="_course__props-item">
              <span class="_course__props-key">Сколько учиться:</span>
              <span class="_course__props-value">4 дня</span>
            </li>
          </ul>
          <div class="_course__actions">
            <Btn variant="outline">Узнать подробнее</Btn>
            <Btn>Начать учиться</Btn>
          </div>
        </section>

        <SliderOneSlide items={slides} />

        <PromptBlock
          hint="О чем курс?"
          title="Раскроем все тонкости обработок кислотами, реагентами и природе воздействия"
          description="В течение курса слушатели узнают о современных научно-технических решениях в области СКО, ОПЗ, ОВП и ключевых показателях эффективности операций, освоят критерии оценки эффективности обработок в карбонатных и терригенных коллекторах, научаться создавать цифровые модели скважин и моделировать обработки в симуляторах RockStim и попробуют себя в роли практиков лабораторных экспериментов при проведении обработок ПЗП."
        />

        <HorizontalBanner
          backgroundColor="#353749"
          title="Оформи сейчас и получи бонусы:"
          image={product2Image}
          imageAlt=""
        >
          <Fragment slot="description">
            <ul>
              <li>Две недели пользования симулятором RockStim</li>
              <li>
                Смоделируем для Вас цифровую модель скважины и подберем лучший
                дизайн кислотного воздействия
              </li>
              <li>Удостоверение о повышении квалификации</li>
              <li>Электронные материалы курса</li>
            </ul>
          </Fragment>
          <Fragment slot="footer">
            <h3 class="_horizontal-banner__bottom-title">
              70 000 ₽ за 4 дня обучения
            </h3>
            <div class="_horizontal-banner__action">
              <Btn block>Начать учиться</Btn>
              <p class="_horizontal-banner__action-text">
                По мере формирования группы
              </p>
            </div>
          </Fragment>
        </HorizontalBanner>

        <PromptBlock
          hint="Для чего курс?"
          title="Углубите экспертизу в оптимизации дизайнов кислотного воздействия в сложнопостроенных терригенных и карбонатных коллекторах. Разбираться в практических эффектах лабораторных экспериментов на приросты нефти."
        />

        <CourseProgram items={courseProgramItems} />

        <Faq items={faqItems} />

        <section
          class="_course__resume"
          style={`background-image: url(${resumeBgImage.src});`}
        >
          <div class="_course__price">
            <h2 class="_course__price-title">Стоимость:</h2>
            <p class="_course__price-subtitle">70 000 ₽ за 4 дня обучения</p>
            <TextContent rootClass="_course__price-text">
              <h3>В курс входит:</h3>
              <ul>
                <li>Две недели пользования симулятором RockStim</li>
                <li>
                  Смоделируем для Вас цифровую модель скважины и подберем лучший
                  дизайн кислотного воздействия
                </li>
                <li>Удостоверение о повышении квалификации</li>
                <li>Электронные материалы курса</li>
              </ul>
            </TextContent>
          </div>
          <div class="_course__feedback">
            <Feedback
              title="Запишитесь на курс"
              descriptionItems={courseFeedbackDescriptionItems}
            >
              <Form hook="form">
                <div class="_form__group">
                  <Input
                    type="text"
                    name="name"
                    id="course-name"
                    label="Имя"
                    required
                  />
                </div>
                <div class="_form__group">
                  <Input
                    type="tel"
                    name="phone"
                    id="course-phone"
                    label="Телефон"
                    hook="phone-mask"
                    required
                  />
                </div>
                <div class="_form__group">
                  <Input
                    type="email"
                    name="email"
                    id="course-email"
                    label="E-mail"
                    required
                  />
                </div>
                <div class="_form__group _form__group--bottom-large">
                  <Btn type="submit" block>Записаться на курс</Btn>
                </div>
                <div class="_form__group">
                  <p class="_form__rules">
                    Заполняя форму, вы соглашаетесь на
                    <a href="#">обработку персональных данных</a>
                  </p>
                </div>
              </Form>
            </Feedback>
          </div>
        </section>
      </div>
    </Container>
  </main>
</Layout>

<style>
  .page-main {
    flex: 1;
  }

  ._course {
    display: grid;
    gap: 160px;
    padding: 224px 0 180px;
  }

  ._course__point {
    margin: 0;
    color: var(--grey-color);
    font-size: 14px;
    font-weight: 400;
    line-height: 114%;
  }

  :global(._course__title) {
    margin-top: 10px;
  }

  ._course__description {
    margin: 44px 0 0;
    font-size: 18px;
    line-height: 155%;
  }

  ._course__props {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    align-items: flex-start;
    gap: 20px;
    margin: 36px 0 0;
    padding: 16px 0 0;
    border-top: 1px solid rgb(0 0 0 / 10%);
    list-style: none;
  }

  ._course__props-item {
    display: grid;
    gap: 4px;
  }

  ._course__props-key {
    color: var(--grey-color);
    font-size: 18px;
  }

  ._course__props-value {
    font-size: 18px;
    font-weight: 600;
  }

  ._course__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 36px;
  }

  ._course__resume {
    display: grid;
    gap: 48px;
    padding: 60px 110px;
    border-radius: 20px;
    background-color: #f8f8f8;
    background-repeat: no-repeat;
    background-position: bottom left;
  }

  ._course__price-title {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  ._course__price-subtitle {
    margin: 29px 0 0;
    color: var(--primary-color);
    font-size: 32px;
    font-weight: 600;
  }

  ._course__price-text {
    margin-top: 47px;
  }

  /* mobile */
  @media (width < 769px) {
    ._course {
      gap: 64px;
      padding: 80px 0;
    }

    ._course__resume {
      padding: 16px;
      border-radius: 12px;
    }
  }

  /* tablet */
  @media (width >= 769px) {
    ._course__resume {
      grid-template-columns: 3fr 2fr;
      padding: 32px;
    }
  }

  /* tablet-only */
  @media (width >= 769px) and (width < 1081px) {
    ._course {
      gap: 100px;
      padding: 120px 0;
    }
  }

  /* desktop */
  @media (width >= 1081px) {
    ._course__description {
      padding-right: 40%;
    }

    ._course__props {
      gap: 45px;
      margin-top: 58px;
      border-top-width: 2px;
    }

    ._course__actions {
      margin-top: 72px;
    }
  }
</style>
