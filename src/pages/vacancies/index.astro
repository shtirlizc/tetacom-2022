---
import { getCollection } from "astro:content";
import VacanciesFeed from "../../blocks/vacancies/vacancies-feed.astro";
import { getVacancyDepartmentBySlug } from "../../data/vacancy-departments";
import Layout from "../../layouts/layout.astro";
import { getSiteUrl } from "../../utils/site-url";

interface VacancyItem {
  rootClass?: string;
  title: string;
  description: string;
  href: string;
  linkLabel: string;
  itemAttrs?: Record<string, string>;
}

const vacancyEntries = await getCollection(
  "vacancies",
  ({ data }) => data.draft !== true,
);

const sortedVacancyEntries = vacancyEntries.sort(
  (a, b) => a.data.order - b.data.order,
);
const usedDepartmentSlugs = Array.from(
  new Set(sortedVacancyEntries.map(({ data }) => data.department)),
);
const getDepartmentCount = (slug: string) =>
  sortedVacancyEntries.filter(({ data }) => data.department === slug).length;
const filters = [
  {
    label: "Все вакансии",
    href: "/vacancies/",
    active: true,
    count: sortedVacancyEntries.length,
  },
  ...usedDepartmentSlugs.map((slug) => {
    const department = getVacancyDepartmentBySlug(slug);

    return {
      label: department?.label ?? slug,
      href: `/vacancies/tag/${slug}/`,
      active: false,
      count: getDepartmentCount(slug),
    };
  }),
];
const vacancies: VacancyItem[] = sortedVacancyEntries.map(({ data }) => ({
  rootClass: "_vacancies-page__item",
  title: data.title,
  description: data.description,
  href: `/vacancies/${data.slug}/`,
  linkLabel: data.title,
  itemAttrs: {
    "data-vacancy-name": data.department,
  },
}));
---

<Layout title="Вакансии" canonical={getSiteUrl("/vacancies/", Astro.site)}>
  <VacanciesFeed title="Вакансии" filters={filters} vacancies={vacancies} />
</Layout>
