---
import { getCollection, render } from "astro:content";
import Btn from "../../components/btn.astro";
import Container from "../../components/container.astro";
import PageTitle from "../../components/page-title.astro";
import TextContent from "../../components/text-content.astro";
import Layout from "../../layouts/layout.astro";

export async function getStaticPaths() {
  const vacancies = await getCollection(
    "vacancies",
    ({ data }) => data.draft !== true,
  );

  return vacancies.map((vacancy) => ({
    params: { slug: vacancy.data.slug },
    props: { vacancy },
  }));
}

const { vacancy } = Astro.props;
const { Content } = await render(vacancy);
---

<Layout>
  <main class="page-main">
    <Container>
      <div class="_vacancies-inner-page">
        <p class="_vacancies-inner-page__department">
          {vacancy.data.department}
        </p>
        <div class="_vacancies-inner-page__title">
          <PageTitle as="h1">
            {vacancy.data.title}
          </PageTitle>
        </div>
        <p class="_vacancies-inner-page__description">
          {vacancy.data.description}
        </p>

        <div class="_vacancies-inner-page__feedback">
          <Btn href="/vacancies/" variant="text" shape="icon">
            <span>
              <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
                <rect width="52" height="52" rx="26"></rect>
                <path
                  d="M36 26L16 26M16 26L24.4 34M16 26L24.4 18"
                  stroke="white"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
            Назад
          </Btn>
          <Btn type="button" popovertarget="modal-vacancy">Откликнуться</Btn>
          <Btn
            type="button"
            variant="link"
            data-vacancy-share
            aria-label="Скопировать ссылку на вакансию"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M4.5 12.5C5.88071 12.5 7 11.3807 7 10C7 8.61929 5.88071 7.5 4.5 7.5C3.11929 7.5 2 8.61929 2 10C2 11.3807 3.11929 12.5 4.5 12.5Z"
                stroke="#3C5DF2"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M14.5 18C15.8807 18 17 16.8807 17 15.5C17 14.1193 15.8807 13 14.5 13C13.1193 13 12 14.1193 12 15.5C12 16.8807 13.1193 18 14.5 18Z"
                stroke="#3C5DF2"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M14.5 7C15.8807 7 17 5.88071 17 4.5C17 3.11929 15.8807 2 14.5 2C13.1193 2 12 3.11929 12 4.5C12 5.88071 13.1193 7 14.5 7Z"
                stroke="#3C5DF2"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M12 6L7 9"
                stroke="#3C5DF2"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M7 11L12 14"
                stroke="#3C5DF2"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <span data-vacancy-share-label>Поделиться вакансией</span>
          </Btn>
        </div>

        <div class="_vacancies-inner-page__content">
          <TextContent>
            <Content />
          </TextContent>
        </div>
      </div>
    </Container>
  </main>
</Layout>

<style>
  .page-main {
    flex: 1;
  }

  ._vacancies-inner-page {
    padding: 180px 0 150px;
  }

  ._vacancies-inner-page__department {
    margin: 0;
    color: var(--grey-color);
    font-size: 14px;
    line-height: 171%;
  }

  :global(._vacancies-inner-page__title) {
    margin-top: 10px;
  }

  ._vacancies-inner-page__description {
    margin: 37px 0 0;
    padding-right: 38%;
    font-size: 18px;
    line-height: 156%;
  }

  ._vacancies-inner-page__feedback {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 20px;
    margin-top: 35px;
  }

  ._vacancies-inner-page__content {
    margin-top: 60px;
  }

  /* mobile */
  @media (width < 769px) {
    ._vacancies-inner-page {
      padding: 80px 0;
    }

    ._vacancies-inner-page__description {
      padding-right: 0;
    }
  }

  /* tablet-only */
  @media (width >= 769px) and (width < 1081px) {
    ._vacancies-inner-page {
      padding: 120px 0;
    }
  }
</style>

<script>
  const shareButton = document.querySelector("[data-vacancy-share]");
  const shareButtonLabel = document.querySelector("[data-vacancy-share-label]");
  const defaultShareLabel = shareButtonLabel?.textContent ?? "";

  const copyText = async (text: string) => {
    if (navigator.clipboard) {
      await navigator.clipboard.writeText(text);
      return;
    }

    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.top = "0";
    textarea.style.left = "-9999px";

    document.body.append(textarea);
    textarea.select();
    const fallbackCopy = (
      document as Document & {
        execCommand?: (commandId: string) => boolean;
      }
    ).execCommand;

    fallbackCopy?.call(document, "copy");
    textarea.remove();
  };

  shareButton?.addEventListener("click", async () => {
    try {
      await copyText(window.location.href);

      if (shareButtonLabel) {
        shareButtonLabel.textContent = "Ссылка скопирована";
        window.setTimeout(() => {
          shareButtonLabel.textContent = defaultShareLabel;
        }, 2000);
      }
    } catch {
      if (shareButtonLabel) {
        shareButtonLabel.textContent = "Не удалось скопировать";
        window.setTimeout(() => {
          shareButtonLabel.textContent = defaultShareLabel;
        }, 2000);
      }
    }
  });
</script>
