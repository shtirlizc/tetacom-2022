---
import { getCollection } from "astro:content";
import BlogFeed from "../../blocks/news/blog-feed.astro";
import Layout from "../../layouts/layout.astro";
import { getNewsTagBySlug } from "../../data/news-tags";

const formatPostDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);

const newsEntries = (
  await getCollection("news", ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const usedTagSlugs = Array.from(
  new Set(newsEntries.flatMap(({ data }) => data.tags)),
);
const filters = [
  { label: "Все новости", href: "/news/", active: true },
  ...usedTagSlugs.map((slug) => {
    const tag = getNewsTagBySlug(slug);

    return {
      label: tag?.label ?? slug,
      href: `/news/tag/${slug}/`,
      active: false,
    };
  }),
];
const newsItems = newsEntries.map(({ data }) => ({
  dateText: formatPostDate(data.pubDate),
  dateTime: data.pubDate.toISOString(),
  title: data.title,
  tags: data.tags.map((slug) => {
    const tag = getNewsTagBySlug(slug);

    return {
      label: tag?.label ?? slug,
      href: `/news/tag/${slug}/`,
    };
  }),
  intro: data.description,
  href: `/news/${data.slug}/`,
}));
---

<Layout title="Новости" canonical={new URL("/news/", Astro.site).toString()}>
  <BlogFeed title="Новости" filters={filters} items={newsItems} />
</Layout>
