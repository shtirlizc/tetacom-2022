---
import { getCollection, render } from "astro:content";
import { getNewsTagBySlug } from "../../data/news-tags";
import ArticleLayout from "../../layouts/article-layout.astro";
import { getSiteUrl } from "../../utils/site-url";

export async function getStaticPaths() {
  const posts = await getCollection("news", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const formatPostDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);

const { post } = Astro.props;
const { Content } = await render(post);
const tags = post.data.tags.map((slug: string) => {
  const tag = getNewsTagBySlug(slug);

  return {
    label: tag?.label ?? slug,
    href: `/news/tag/${slug}/`,
  };
});
---

<ArticleLayout
  backHref="/news/"
  dateText={formatPostDate(post.data.pubDate)}
  dateTime={post.data.pubDate.toISOString()}
  title={post.data.title}
  tags={tags}
  seoTitle={post.data.title}
  description={post.data.description}
  canonical={getSiteUrl(`/news/${post.data.slug}/`, Astro.site)}
  type="article"
>
  <Content />
</ArticleLayout>
