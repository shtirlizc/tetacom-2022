---
import { Image } from "astro:assets";
import type { SvgComponent } from "astro/types";
import Btn from "../components/btn.astro";
import Container from "../components/container.astro";
import PageTitle from "../components/page-title.astro";
import PromptBlock from "../components/prompt-block.astro";
import Banner from "../blocks/products/banner.astro";
import InfoBlock from "../blocks/products/info-block.astro";
import Layout from "../layouts/layout.astro";
import opzImage from "../assets/products/opz/opz.png";
import banner1Image from "../assets/products/grp/banner-1.png";
import banner2Image from "../assets/products/grp/banner-2.svg";
import module1Image from "../assets/products/grp/module-1.svg";
import module2Image from "../assets/products/grp/module-2.svg";
import module3Image from "../assets/products/grp/module-3.svg";
import module4Image from "../assets/products/grp/module-4.svg";
import module5Image from "../assets/products/grp/module-5.svg";
import youtubeIcon from "../assets/icons/icon-youtube.svg";

const Banner2 = banner2Image;
const Module1 = module1Image;
const Module2 = module2Image;
const Module3 = module3Image;
const Module4 = module4Image;
const Module5 = module5Image;
const YoutubeIcon = youtubeIcon;

interface ProductModule {
  title: string;
  description: string;
  Icon: SvgComponent;
}

interface InfoItem {
  titleLines: string[];
  points: string[];
}

type BannerItem =
  | {
      dir: "horizontal";
      rootClass?: string;
      backgroundColor?: string;
      title: string;
      description: string;
      image: ImageMetadata;
      imageAlt?: string;
    }
  | {
      dir: "vertical";
      title: string;
      description: string;
      hasImage: true;
      image: SvgComponent;
    }
  | {
      dir: "vertical";
      title: string;
      description: string;
      hasImage?: false;
      image?: undefined;
    };

const modules: ProductModule[] = [
  {
    title: "Построение модели",
    description:
      "Расчет протравленной и остаточной ширины трещины, динамики снижения проводимости в процессе эксплуатации",
    Icon: Module1,
  },
  {
    title: "Интерпретация данных ГИС",
    description: "Загрузка данных, обработка данных ГИС/РИГИС",
    Icon: Module2,
  },
  {
    title: "Расчёты",
    description:
      "Прогнозирование динамики забойного и устьевого давлений в процессе проведения ГРП",
    Icon: Module3,
  },
  {
    title: "Аналитика",
    description: "Построение прогнозных режимов работы скважины после ГРП",
    Icon: Module4,
  },
  {
    title: "Тестовые закачки",
    description:
      "Прогнозирование динамики забойного и устьевого давлений в процессе проведения ГРП",
    Icon: Module5,
  },
];

const banners: BannerItem[] = [
  {
    dir: "horizontal",
    rootClass: "_product-page__banners-wide",
    backgroundColor: "var(--primary-color)",
    title: "Расчет геометрии трещины с использованием продвинутой P3D модели",
    description:
      "Проведение расчётов ГРП трещин с исходными данными. Возможность удобного размещение планшета геометрии трещин ГРП. Блок многовариантных расчетов с варьированием геомеханических и технологических параметров ГРП.",
    image: banner1Image,
    imageAlt: "",
  },
  {
    dir: "vertical",
    title: "Планшет геомеханики",
    description:
      "Построение 1D-геомеханической и петрофизической модели пласта. Автоматическая подгрузка лабораторных исследований керна, данных специальных методов ГИС (АКШ, ГГкП). Работа с данными – линейные преобразования, растяжения значений.",
    hasImage: true,
    image: Banner2,
  },
  {
    dir: "vertical",
    title: "Загрузка данных ГИС",
    description:
      "Интерпретация литотипов и петрофизических свойств пласта по данным ГИС. Возможность корректировки и построение данных ГИС, с последующей выгрузкой данных).",
  },
];

const infoItems: InfoItem[] = [
  {
    titleLines: ["Что находится", "в разработке"],
    points: [
      "Модель оседания пропанта в трещине ГРП",
      "Математическая модель PL3D развития трещины ГРП",
      "Модуль для прогноза вероятности осложнений в ГС",
    ],
  },
  {
    titleLines: ["Предоставим всё", "необходимое", "для старта"],
    points: [
      "Пробные версии с сопровождением",
      "Демонстрация работы симулятора на реальной скважине",
      "Обучение и сервисное обслуживание",
    ],
  },
];
---

<Layout>
  <main class="page-main">
    <div class="_product-page">
      <Container>
        <PageTitle as="h1" rootClass="_product-page__title" mobileAlign="center">
          Симулятор гидроразрыва пласта
        </PageTitle>
        <p class="_product-page__description">
          Расчетный инструмент для проектирования и оптимизации ключевых
          технико-экономических параметров проведения ГРП
        </p>
        <div class="_product-page__actions">
          <Btn href="#" variant="outline">Вход в сервис</Btn>
          <Btn>Заказать демонстрацию</Btn>
        </div>

        <div class="_product-page__picture">
          <a
            data-fslightbox="product-video"
            data-video
            href="https://www.youtube.com/watch?v=3nQNiWdeH2Q"
          >
            <Image src={opzImage} alt="" />
            <span class="_product-page__video-icon">
              <YoutubeIcon aria-hidden="true" focusable="false" />
            </span>
          </a>
        </div>

        <PromptBlock
          rootClass="_product-page__prompt-1"
          hint="Кто мы?"
          title="Мы использовали Pseudo3D-модель"
          description="Модель развития трещины ГРП, численная модель кислотного растворения КГРП, с усовершенствованной модель оценки остаточной проводимости закрепленной трещины КГРП (Nasr-el-Din (Nierode-Kruk)). Возможность учета термодинамических эффектов в скважине и трещине ГРП"
        />

        <section class="_product-page__banners">
          {banners.map((banner) => <Banner banner={banner} />)}
        </section>

        <PromptBlock
          rootClass="_product-page__prompt-2"
          hint="Кто мы?"
          title="Мы использовали Pseudo3D-модель"
          description="Модель развития трещины ГРП, численная модель кислотного растворения КГРП, с усовершенствованной модель оценки остаточной проводимости закрепленной трещины КГРП (Nasr-el-Din (Nierode-Kruk)). Возможность учета термодинамических эффектов в скважине и трещине ГРП"
        />
      </Container>

      <section class="_product-page__modules">
        <Container>
          <h2 class="_product-page__modules-title">Модули симулятора</h2>
          <div class="_product-page__modules-body">
            {
              modules.map(({ title, description, Icon }) => (
                <div class="_product-page__module">
                  <div class="_product-page__module-image">
                    <Icon aria-hidden="true" focusable="false" />
                  </div>
                  <h3 class="_product-page__module-title">{title}</h3>
                  <p class="_product-page__module-description">{description}</p>
                </div>
              ))
            }
          </div>
        </Container>
      </section>

      <Container>
        <section class="_product-page__info-block">
          <InfoBlock items={infoItems} />
        </section>
      </Container>
    </div>
  </main>
</Layout>

<style>
  .page-main {
    flex: 1;
  }

  ._product-page {
    padding: 220px 0 0;
  }

  :global(._product-page__title) {
    margin: 0;
  }

  ._product-page__description {
    margin: 45px 0 0;
    font-size: 18px;
    line-height: 1.6em;
  }

  ._product-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 72px;
  }

  ._product-page__picture {
    margin-top: 162px;
  }

  ._product-page__picture a {
    position: relative;
    display: inline-block;
    width: 100%;
    overflow: hidden;
  }

  ._product-page__picture :global(img) {
    width: 100%;
    height: auto;
  }

  ._product-page__video-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: transform var(--delay) ease-in-out;
  }

  ._product-page__video-icon :global(svg) {
    width: 72px;
    height: 72px;
  }

  ._product-page__picture a:hover ._product-page__video-icon {
    transform: scale(1.05);
  }

  :global(._product-page__prompt-1) {
    margin-top: 160px;
  }

  ._product-page__banners {
    --image-width: 520px;

    display: grid;
    gap: 20px;
    margin-top: 160px;
  }

  ._product-page__modules {
    margin-top: 220px;
    padding: 100px 0 140px;
    background-color: #f8f8f8;
  }

  ._product-page__modules-title {
    margin: 0;
    font-size: 40px;
    font-weight: 600;
    line-height: 47px;
    text-align: center;
  }

  ._product-page__modules-body {
    display: grid;
    gap: 100px 20px;
    margin-top: 100px;
  }

  ._product-page__module {
    padding: 0 32px 40px;
    border-radius: 20px;
    background-color: var(--bg-color);
  }

  ._product-page__module-image {
    width: 100%;
    max-width: 190px;
    height: 140px;
    margin: auto;
    transform: translateY(-55%);
  }

  ._product-page__module-image :global(svg) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  ._product-page__module-title {
    margin: -11% 0 0;
    font-size: 24px;
    font-weight: 600;
    line-height: 28px;
  }

  ._product-page__module-description {
    margin: 28px 0 0;
    font-size: 18px;
    line-height: 156%;
  }

  ._product-page__info-block {
    margin: 60px 0;
  }

  /* mobile */
  @media (width < 769px) {
    ._product-page {
      padding: 80px 0 0;
    }

    ._product-page__description {
      margin-top: 32px;
      text-align: center;
    }

    ._product-page__actions {
      justify-content: center;
      margin-top: 40px;
    }

    ._product-page__picture {
      margin-top: 64px;
    }

    :global(._product-page__prompt-1) {
      margin-top: 64px;
    }

    ._product-page__banners {
      --image-width: 240px;
      margin-top: 64px;
    }

    ._product-page__modules {
      margin-top: 80px;
      padding: 50px 0 70px;
    }

    ._product-page__module-title {
      margin: -70px 0 0;
    }
  }

  /* tablet */
  @media (width >= 769px) {
    ._product-page__banners {
      grid-template-columns: 1fr 1fr;
      padding-bottom: calc(var(--image-width) / 4);
    }

    :global(._product-page__banners-wide) {
      grid-column: 1 / 3;
    }
  }

  /* tablet-only */
  @media (width >= 769px) and (width < 1081px) {
    ._product-page {
      padding: 120px 0 0;
    }

    ._product-page__picture {
      margin-top: 92px;
    }

    ._product-page__modules-body {
      grid-template-columns: repeat(2, 1fr);
      gap: 128px 20px;
      margin-top: 140px;
    }
  }

  /* desktop */
  @media (width >= 1081px) {
    ._product-page__description {
      padding-right: 40%;
    }

    ._product-page__banners {
      padding-bottom: calc(var(--image-width) / 2);
    }

    ._product-page__modules-body {
      grid-template-columns: repeat(3, 1fr);
      margin-top: 140px;
    }

    ._product-page__info-block {
      margin: 180px 0;
    }
  }
</style>
